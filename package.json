{
  "name": "@kondeio/kdf",
  "version": "0.1.1",
  "description": "Agent-first design consistency for Node-powered web apps. KDF gives AI agents a JSON source of truth for consistent UI.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "kdf": "dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./plugin": {
      "import": "./dist/plugin.js",
      "types": "./dist/plugin.d.ts"
    }
  },
  "files": [
    "dist",
    "docs",
    "kdf",
    "example",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "postinstall": "node dist/postinstall.js",
    "typecheck": "tsc --noEmit",
    "test": "bun unit-test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KondeIO/kdf.git"
  },
  "homepage": "https://github.com/KondeIO/kdf#readme",
  "bugs": {
    "url": "https://github.com/KondeIO/kdf/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "peerDependencies": {
    "next": ">=14"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.0.0",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "design-system",
    "json",
    "node",
    "nextjs",
    "astro",
    "hono",
    "design-tokens"
  ]
}
